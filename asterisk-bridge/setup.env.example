# ---------------------------------------------------------------------------
# Lunara Asterisk Bridge — установочный конфиг (один раз, для setup.sh)
# ---------------------------------------------------------------------------
# Скопируйте этот файл в setup.env и заполните значения:
#   cp setup.env.example setup.env && nano setup.env
# После этого запустите: sudo bash setup.sh
# ---------------------------------------------------------------------------

# --- Обязательно ---

# Ключ Gemini API (Google AI Studio → https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# UUID агента, скопируйте из адресной строки Lovable, когда открыт агент
# (…/agents/<UUID>). Один мост = один агент.
LOVABLE_AGENT_ID=

# Webhook-секрет агента. В UI Lovable откройте агента → секция «Asterisk /
# Webhook secret» → нажмите «Сгенерировать» и вставьте сюда то же значение.
LOVABLE_WEBHOOK_SECRET=

# --- Необязательно (есть дефолты) ---

# Базовый URL Lovable-приложения. По умолчанию production-домен pecalls.
LOVABLE_BASE_URL=https://pecalls.lovable.app

# Пользователь ARI, который создаст скрипт. По умолчанию: lunara
ARI_USERNAME=lunara

# Пароль ARI. Если пусто — setup.sh сгенерирует случайный (32 hex-символа)
# и распечатает в финальном блоке "СКОПИРУЙ ЭТО В LOVABLE".
ARI_PASSWORD=

# TCP-порт, на котором мост слушает AudioSocket от Asterisk.
# По умолчанию: 8090. Должен быть открыт от Asterisk-хоста до этого сервиса.
AUDIOSOCKET_PORT=8090
