# Lunara HMAC shared secret (min 16 chars). Generate: openssl rand -hex 32
LUNARA_HMAC_SECRET=

# Bind port
PORT=8080

# Optional: comma-separated list of source IPs allowed to call this gateway.
# Leave empty to allow all (useful behind a private tunnel / WireGuard).
LUNARA_ALLOWED_IPS=

# Retention: hard-delete audio + DB rows older than N days. 0 = disabled.
RETENTION_DAYS=180

# PostgreSQL
DATABASE_URL=postgres://gateway:gateway@postgres:5432/gateway

# MinIO / S3-compatible storage
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=call-recordings

# Twilio recording download
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Transcription backend: gemini | whisper
TRANSCRIBE_BACKEND=gemini
GEMINI_API_KEY=
WHISPER_URL=http://whisper:9000
