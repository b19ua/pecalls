# Shared secret with Lunara — MUST match the value pasted into "Data residency"
LUNARA_HMAC_SECRET=replace-me-with-a-long-random-string

# PostgreSQL
DATABASE_URL=postgres://gateway:gateway@postgres:5432/gateway

# MinIO (S3-compatible object storage)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=call-recordings
S3_PUBLIC_BASE=                  # optional CDN/public base URL; signed URLs used when empty

# Twilio (needed to download recordings from api.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Transcription
TRANSCRIBE_BACKEND=gemini        # gemini | whisper
GEMINI_API_KEY=                  # if backend=gemini
WHISPER_URL=http://whisper:9000  # if backend=whisper

# Optional housekeeping
RETENTION_DAYS=0                 # 0 disables auto-delete
PORT=8080
